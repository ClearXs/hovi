{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hovi",
  "version": "0.1.0",
  "identifier": "cc.hovi.ui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "pnpm clean:tauri-runtime-staging && pnpm -C .. build && pnpm build:web-static && pnpm prepare:gateway-sidecar",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Hovi",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/runtime": "runtime"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
